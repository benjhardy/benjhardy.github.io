---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import AppPreview from '../../components/AppPreview.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';

export async function getStaticPaths() {
    const apps = (await getCollection('apps')).sort(sortItemsByDateDesc);
    const appCount = apps.length;
    return apps.map((app, index) => ({
        params: { id: app.id },
        props: {
            app,
            prevApp: index + 1 !== appCount ? apps[index + 1] : null,
            nextApp: index !== 0 ? apps[index - 1] : null
        }
    }));
}

type Props = {
    app: CollectionEntry<'apps'>;
    prevApp: CollectionEntry<'apps'> | null;
    nextApp: CollectionEntry<'apps'> | null;
};

const { app, prevApp, nextApp } = Astro.props;
const { title, description, seo, repo, appStoreUrl, playStoreUrl } = app.data;
const { Content } = await render(app);
---

<BaseLayout title={seo?.title ?? title} description={seo?.description ?? description} image={seo?.image} pageType="article" showHeader={false}>
    <article class="mb-16 sm:mb-24">
        <header class="mb-8">
            <h1 class="text-3xl leading-tight font-serif font-medium sm:text-5xl sm:leading-tight">{title}</h1>
            <div class="mt-2 flex flex-wrap gap-4">
                {repo && (
                    <a href={repo} target="_blank" rel="noopener noreferrer" class="text-sm underline underline-offset-2 hover:no-underline">
                        Source / GitHub
                    </a>
                )}
                {appStoreUrl && (
                    <a href={appStoreUrl} target="_blank" rel="noopener noreferrer" class="text-sm underline underline-offset-2 hover:no-underline">
                        App Store
                    </a>
                )}
                {playStoreUrl && (
                    <a href={playStoreUrl} target="_blank" rel="noopener noreferrer" class="text-sm underline underline-offset-2 hover:no-underline">
                        Google Play
                    </a>
                )}
            </div>
        </header>
        <div class="max-w-none prose sm:prose-lg">
            <Content />
        </div>
    </article>
    {
        (prevApp || nextApp) && (
            <div class="my-16 sm:my-24">
                <h2 class="mb-12 text-xl font-serif italic sm:mb-16 sm:text-2xl">View Next</h2>
                {nextApp && <AppPreview app={nextApp} class="mb-10 sm:mb-12" headingLevel="h3" />}
                {prevApp && <AppPreview app={prevApp} class="mb-10 sm:mb-12" headingLevel="h3" />}
            </div>
        )
    }
</BaseLayout>
